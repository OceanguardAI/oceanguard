# Credentials for the live Sentinel-1 -> YOLO pipeline (run_live_pipeline.py).
#
# Create an OAuth client (free tier) at:
#   https://shapps.dataspace.copernicus.eu/dashboard/#/account/settings
# Copy the generated Client ID and Secret here.
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# Where to push generated YOLO_SAR events. Local dev: http://localhost:8000
# Production: your deployed Cloud Run backend URL.
BACKEND_URL=http://localhost:8000

# Monitored bounding box: min_lon min_lat max_lon max_lat (passed via --bbox).
# Default in code = Bar Reef, Sri Lanka: 79.4 8.0 79.9 8.8
