# Vertex AI example settings for repo-root scripts such as `test_vertex.py`.
# Copy this file to `.env` when you want to run the local Vertex AI smoke test.

GOOGLE_CLOUD_PROJECT=oceaneyelabs
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
GEMINI_MODEL=gemini-2.5-flash

# Existing backend/runtime options can still live in `.env` too when needed.
GEMINI_USE_GCP=true
GEMINI_API_KEY=
AGENT_MAX_TOOL_ROUNDS=5
AGENT_NARRATOR_MAX_TOKENS=500
AGENT_BRIEFING_MAX_TOKENS=400
AGENT_PATROL_MAX_TOKENS=600
AGENT_ASK_MAX_TOKENS=700
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
