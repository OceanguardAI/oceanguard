# OceanGuard backend Gemini config for Vertex AI mode.
# GEMINI_API_KEY must stay empty when GEMINI_USE_GCP=true.

GEMINI_USE_GCP=true
GOOGLE_CLOUD_PROJECT=oceaneyelabs
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# --- Live data ingestion ---
# Global Fishing Watch API token: https://globalfishingwatch.org/our-apis/tokens
GFW_API_TOKEN=
# AISStream.io real-time AIS key (optional): https://aisstream.io
AISSTREAM_API_KEY=
# Monitored area bbox as JSON [min_lon,min_lat,max_lon,max_lat] (default Bar Reef, Sri Lanka)
GFW_REGION_BBOX=[79.4,8.0,79.9,8.8]
GFW_LOOKBACK_DAYS=90
GFW_INGEST_ON_STARTUP=true

# Optional runtime overrides
# AGENT_MAX_TOOL_ROUNDS=5
# AGENT_NARRATOR_MAX_TOKENS=500
# AGENT_BRIEFING_MAX_TOKENS=400
# AGENT_PATROL_MAX_TOKENS=600
# AGENT_ASK_MAX_TOKENS=700
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
